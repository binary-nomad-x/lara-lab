                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/todos/1",
                            "host": ["{{base_url}}"],
                            "path": ["todos", "1"]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Update Todo",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Updated task title\",\n    \"description\": \"Updated description\",\n    \"priority\": \"medium\",\n    \"completed\": false\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/todos/1",
                            "host": ["{{base_url}}"],
                            "path": ["todos", "1"]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Toggle Complete",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/todos/1/toggle",
                            "host": ["{{base_url}}"],
                            "path": ["todos", "1", "toggle"]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Delete Todo",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/todos/1",
                            "host": ["{{base_url}}"],
                            "path": ["todos", "1"]
                        }
                    },
                    "response": []
